{
  "_comment": "Contenido funcional de politicas IAM. Corrige duplicados y alinea con el stack sin cambiar permisos efectivos.",
  "executionPolicy": {
    "_comment": "Permisos del CloudFormation execution role por proyecto (en funcion de allowedServices).",
    "serviceActionsByService": {
      "lambda": [
        "lambda:*"
      ],
      "dynamodb": [
        "dynamodb:*"
      ],
      "sqs": [
        "sqs:*"
      ],
      "apigateway": [
        "apigateway:PUT",
        "apigateway:PATCH",
        "apigateway:GET"
      ],
      "s3": [
        "s3:*"
      ],
      "glue": [
        "glue:*"
      ],
      "athena": [
        "athena:*"
      ],
      "events": [
        "events:*"
      ],
      "secretsmanager": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret",
        "secretsmanager:CreateSecret",
        "secretsmanager:DeleteSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:TagResource"
      ],
      "logs": [
        "logs:*"
      ],
      "quicksight": [
        "quicksight:*"
      ],
      "bedrock": [
        "bedrock:InvokeModel",
        "bedrock:ListFoundationModels"
      ],
      "cloudfront": [
        "cloudfront:*"
      ],
      "route53": [
        "route53:*"
      ],
      "ecr": [
        "ecr:CreateRepository",
        "ecr:DescribeRepositories",
        "ecr:DeleteRepository",
        "ecr:SetRepositoryPolicy",
        "ecr:TagResource"
      ],
      "states": [  
        "states:*"
      ]
    },
    "additionalActions": [
      "logs:*",
      "ssm:GetParameter",
      "ssm:GetParameters",
      "ssm:GetParametersByPath",
      "ssm:DescribeParameters",
      "apigateway:PUT",
      "apigateway:PATCH",
      "apigateway:GET"
    ],
    "iamMinimalActions": [
      "iam:CreateRole",
      "iam:DeleteRole",
      "iam:GetRole",
      "iam:GetRolePolicy",
      "iam:PassRole",
      "iam:AttachRolePolicy",
      "iam:DetachRolePolicy",
      "iam:PutRolePolicy",
      "iam:DeleteRolePolicy",
      "iam:TagRole",
      "iam:UntagRole"
    ],
    "tagEnforcementCreateActionsByService": {
      "lambda": [
        "lambda:CreateFunction"
      ],
      "dynamodb": [
        "dynamodb:CreateTable"
      ],
      "sqs": [
        "sqs:CreateQueue"
      ],
      "s3": [
        "s3:CreateBucket"
      ],
      "glue": [
        "glue:CreateJob"
      ],
      "secretsmanager": [
        "secretsmanager:CreateSecret"
      ]
    }
  },

  "developersGroupPolicy": {
    "_comment": "Permisos del grupo developers: solo puede asumir roles de despliegue CDK. Se deniega cualquier otra accion directa.",
    "allowAssumeRoleActions": [
      "sts:AssumeRole"
    ],
    "denyEverythingExceptActions": [
      "sts:AssumeRole",  
      "ssm:GetParameter",  
      "ssm:GetParameters",  
      "ssm:GetParametersByPath",  
      "ssm:DescribeParameters"
    ]
  },

  "viewersGroupPolicy": {
    "_comment": "Permisos de solo lectura para seguimiento de despliegues y estado.",
    "readOnlyActions": [
      "cloudformation:Describe*",
      "cloudformation:List*",
      "cloudformation:Get*"
    ]
  },

  "architectsGroupPolicy": {
    "_comment": "Permisos para architects. Mantiene comportamiento actual (sin reducir permisos). El filtrado por servicios se hace en el stack.",
    "allowAssumeRoleActions": [
      "sts:AssumeRole"
    ],
    "denyDirectServicesExceptActions": [
      "sts:AssumeRole",
      "cloudformation:*",
      "cloudformation:ValidateTemplate",
      "iam:Get*",
      "iam:List*",
      "iam:PassRole",
      "ce:GetCostAndUsage",
      "ce:GetCostForecast",
      "ce:GetDimensionValues",
      "ce:GetTags",
      "ce:ListCostAllocationTags",
      "lambda:*",
      "s3:*",
      "glue:*",
      "athena:*",
      "events:*",
      "logs:*",
      "cloudwatch:*",
      "dynamodb:*",
      "sqs:*",
      "secretsmanager:*",
      "apigateway:*",
      "quicksight:*",
      "ssm:*",
      "logs:Describe*",
      "logs:Get*",
      "logs:List*",
      "logs:Filter*",
      "logs:StartQuery",
      "logs:StopQuery",
      "logs:GetQueryResults",
      "cloudwatch:Describe*",
      "cloudwatch:Get*",
      "cloudwatch:List*",
      "ssm:GetParameter",
      "ssm:GetParameters",
      "ssm:GetParametersByPath",
      "ssm:DescribeParameters"
    ],
    "bedrock": [
      "bedrock:InvokeModel",
      "bedrock:ListFoundationModels"
    ]
  }
}
